<script>
    // ── State ────────────────────────────────────────────────
    // Single source of truth — like React state but vanilla JS.
    // All panels (docs, install, example) are always in sync.
    const PANELS = ['docs', 'install', 'example'];
    const STORAGE_KEY = 'ctoon-docs';

    const state = {
        theme: 'dark',
        lang:  'cli',
    };

    function setState(patch) {
        Object.assign(state, patch);
        localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
        render();
    }

    function render() {
        // Theme
        document.documentElement.setAttribute('data-theme', state.theme);
        document.getElementById('hljs-theme-dark').disabled  = (state.theme !== 'dark');
        document.getElementById('hljs-theme-light').disabled = (state.theme !== 'light');

        // Tabs — sync all panels to state.lang, fallback to first tab if lang absent
        PANELS.forEach(panel => {
            const btns  = document.querySelectorAll('#' + panel + '-tabs .tab-btn');
            const panes = document.querySelectorAll('#' + panel + '-panel .tab-content');

            // Check if this panel actually has the requested lang
            const targetPane = document.getElementById(panel + '-' + state.lang);
            const effectiveLang = targetPane ? state.lang : (btns[0] ? btns[0].dataset.tab.replace(panel + '-', '') : null);
            if (!effectiveLang) return;

            btns.forEach(btn => {
                btn.classList.toggle('active', btn.dataset.tab === panel + '-' + effectiveLang);
            });
            panes.forEach(pane => {
                pane.classList.toggle('active', pane.id === panel + '-' + effectiveLang);
            });
        });
    }

    // ── Init ─────────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', () => {
        // Restore persisted state
        try {
            const saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
            if (saved.theme) state.theme = saved.theme;
            if (saved.lang)  state.lang  = saved.lang;
        } catch (e) {}

        render();

        hljs.configure({ ignoreUnescapedHTML: true });
        hljs.highlightAll();
    });

    // ── Public API ───────────────────────────────────────────
    function switchTab(panel, lang) {
        // panel arg is ignored — all panels always sync to the same lang
        setState({ lang });
    }

    function toggleTheme() {
        setState({ theme: state.theme === 'dark' ? 'light' : 'dark' });
    }

    // ── Copy button ──────────────────────────────────────────
    function copyCode(btn) {
        const code = btn.closest('.code-wrap').querySelector('pre code') ||
                     btn.closest('.code-wrap').querySelector('pre');
        navigator.clipboard.writeText(code.innerText).then(() => {
            btn.innerHTML = '<i class="fa-solid fa-check"></i> copied!';
            btn.classList.add('copied');
            setTimeout(() => { btn.innerHTML = '<i class="fa-regular fa-copy"></i> copy'; btn.classList.remove('copied'); }, 1800);
        });
    }
</script>
</body>
</html>