<script>
    // ── Theme ────────────────────────────────────────────────
    function applyTheme(theme) {
        document.documentElement.setAttribute('data-theme', theme);
        document.getElementById('hljs-theme-dark').disabled  = (theme !== 'dark');
        document.getElementById('hljs-theme-light').disabled = (theme !== 'light');
    }
    const saved = localStorage.getItem('ctoon-docs-theme') || 'dark';
    applyTheme(saved);

    function toggleTheme() {
        const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        applyTheme(next);
        localStorage.setItem('ctoon-docs-theme', next);
    }

    // ── highlight.js ─────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', () => {
        hljs.configure({ ignoreUnescapedHTML: true });
        hljs.highlightAll();
    });

    // ── Tab switching ────────────────────────────────────────
    function switchTab(panel, lang) {
        document.querySelectorAll('#' + panel + '-panel .tab-content').forEach(el => el.classList.remove('active'));
        document.querySelectorAll('#' + panel + '-tabs .tab-btn').forEach(btn => btn.classList.remove('active'));
        const content = document.getElementById(panel + '-' + lang);
        if (content) content.classList.add('active');
        const btn = document.querySelector('#' + panel + '-tabs [data-tab="' + panel + '-' + lang + '"]');
        if (btn) btn.classList.add('active');

        const other = panel === 'install' ? 'example' : 'install';
        const oc = document.getElementById(other + '-' + lang);
        if (oc) {
            document.querySelectorAll('#' + other + '-panel .tab-content').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('#' + other + '-tabs .tab-btn').forEach(b => b.classList.remove('active'));
            oc.classList.add('active');
            const ob = document.querySelector('#' + other + '-tabs [data-tab="' + other + '-' + lang + '"]');
            if (ob) ob.classList.add('active');
        }
    }

    // ── Copy button ──────────────────────────────────────────
    function copyCode(btn) {
        const code = btn.closest('.code-wrap').querySelector('pre code') ||
                     btn.closest('.code-wrap').querySelector('pre');
        navigator.clipboard.writeText(code.innerText).then(() => {
            btn.innerHTML = '<i class="fa-solid fa-check"></i> copied!';
            btn.classList.add('copied');
            setTimeout(() => { btn.innerHTML = '<i class="fa-regular fa-copy"></i> copy'; btn.classList.remove('copied'); }, 1800);
        });
    }
</script>
</body>
</html>