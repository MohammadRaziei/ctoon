<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="../ctoon-sq.svg" type="image/svg+xml">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="icon" href="../ctoon-sq.svg" type="image/svg+xml">
    <title>@PROJECT_NAME@ Coverage Report</title>
    <style>
        :root {
            --bg:           #0f0f12;
            --bg2:          #1a1a1f;
            --bg3:          #242429;
            --fg:           #e8e8f0;
            --fg2:          #9090a0;
            --fg3:          #606070;
            --border:       #2a2a35;
            --accent:       #4dabf7;
            --accent-glow:  rgba(77,171,247,0.15);
            --accent-glow2: rgba(77,171,247,0.06);
            --cov-high:     #40c057;
            --cov-med:      #fcc419;
            --cov-low:      #ff6b6b;
            --shadow-sm:    0 1px 3px rgba(0,0,0,0.4);
            --shadow-md:    0 4px 12px rgba(0,0,0,0.5);
            --shadow-blue:  0 4px 20px rgba(77,171,247,0.2);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: var(--bg);
            color: var(--fg);
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            line-height: 1.6;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ── Topbar ── */
        .navbar {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0 2rem;
            height: 60px;
            background: var(--bg2);
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .navbar-logo { width: 32px; height: 32px; flex-shrink: 0; }
        .navbar-logo > * { width: 100%; height: auto; }

        .navbar-brand {
            font-size: 1rem;
            font-weight: 700;
            color: var(--fg);
            letter-spacing: -0.02em;
        }

        .navbar-title {
            font-size: 0.8rem;
            color: var(--fg2);
            margin-left: 0.5rem;
            padding-left: 0.75rem;
            border-left: 1px solid var(--border);
        }

        .navbar-back {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            font-size: 0.8rem;
            font-weight: 500;
            color: var(--fg2);
            text-decoration: none;
            padding: 0.3rem 0.7rem;
            border: 1px solid var(--border);
            transition: all 0.18s;
        }

        .navbar-back:hover { color: var(--accent); border-color: var(--accent); background: var(--accent-glow2); }

        /* ── Hero ── */
        .hero {
            text-align: center;
            padding: 3.5rem 2rem 2.5rem;
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: -60px; left: 50%; transform: translateX(-50%);
            width: 600px; height: 300px;
            background: radial-gradient(ellipse at center, var(--accent-glow) 0%, transparent 70%);
            pointer-events: none;
        }

        .hero-label {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--accent);
            background: var(--accent-glow2);
            border: 1px solid var(--accent-glow);
            padding: 0.25rem 0.8rem;
            border-radius: 999px;
            margin-bottom: 1.2rem;
            font-family: 'IBM Plex Mono', monospace;
        }

        .hero h1 {
            font-size: 2.4rem;
            font-weight: 800;
            letter-spacing: -0.04em;
            margin-bottom: 0.75rem;
            background: linear-gradient(135deg, var(--accent) 0%, #22b8cf 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero p {
            font-size: 1rem;
            color: var(--fg2);
            max-width: 520px;
            margin: 0 auto;
            line-height: 1.75;
        }

        /* ── Main ── */
        main {
            flex: 1;
            padding: 2.5rem 2rem 4rem;
            max-width: 1200px;
            margin: 0 auto;
            width: 100%;
        }

        .section-label {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: var(--accent);
            font-family: 'IBM Plex Mono', monospace;
            margin-bottom: 1rem;
        }

        /* ── Cards grid ── */
        .cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 1.25rem;
        }

        .navbar-brand-link {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            text-decoration: none;
            color: var(--fg);
        }

        .navbar-brand-link:hover .navbar-brand { color: var(--accent); }
        .navbar-brand { transition: color 0.15s; }

        .card {
            background: var(--bg2);
            border: 1px solid var(--border);
            padding: 1.5rem;
            box-shadow: var(--shadow-sm);
            transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            gap: 0;
        }

        /* shine — color injected via --card-color by JS */
        .card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 50% -20%, color-mix(in srgb, var(--card-color, var(--accent)) 15%, transparent) 0%, transparent 65%);
            opacity: 0;
            transition: opacity 0.25s;
            pointer-events: none;
            z-index: 0;
        }

        .card::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(255,255,255,0.04) 0%, transparent 60%);
            pointer-events: none;
            z-index: 0;
        }

        .card > * { position: relative; z-index: 1; }

        .card:hover {
            border-color: var(--card-color, var(--accent));
            box-shadow: 0 4px 20px color-mix(in srgb, var(--card-color, var(--accent)) 22%, transparent), var(--shadow-md);
            transform: translateY(-3px);
        }

        .card:hover::before { opacity: 1; }

        /* ── Card header ── */
        .card-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: 1rem;
        }

        .card-icon {
            width: 46px;
            height: 46px;
            background: linear-gradient(135deg, var(--accent) 0%, #339af0 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 2px 8px rgba(77,171,247,0.3);
            flex-shrink: 0;
        }

        .card-icon svg { width: 22px; height: 22px; color: #fff; }

        .badge {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 0.65rem;
            font-weight: 600;
            padding: 0.2rem 0.6rem;
            border-radius: 999px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            border: 1px solid;
        }

        .card-title {
            font-size: 1.05rem;
            font-weight: 700;
            letter-spacing: -0.015em;
            margin-bottom: 0.35rem;
            color: var(--fg);
        }

        .card-desc {
            font-size: 0.85rem;
            color: var(--fg2);
            line-height: 1.6;
            flex: 1;
            margin-bottom: 1.25rem;
        }

        /* ── Coverage bar ── */
        .cov-bar-wrap {
            margin-bottom: 1.25rem;
        }

        .cov-bar-top {
            display: flex;
            justify-content: space-between;
            font-size: 0.75rem;
            color: var(--fg2);
            font-family: 'IBM Plex Mono', monospace;
            margin-bottom: 0.4rem;
        }

        .cov-bar-track {
            height: 4px;
            background: var(--bg3);
            border: 1px solid var(--border);
            overflow: hidden;
        }

        .cov-bar-fill {
            height: 100%;
            transition: width 0.6s ease;
        }

        /* ── Actions ── */
        .card-footer {
            display: flex;
            gap: 0.75rem;
            padding-top: 1rem;
            border-top: 1px solid var(--border);
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.4rem;
            padding: 0.5rem 1rem;
            font-size: 0.82rem;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.18s;
            cursor: pointer;
            border: none;
        }

        .btn-primary {
            background: var(--accent);
            color: #fff;
            flex: 1;
        }

        .btn-primary:hover { filter: brightness(1.15); box-shadow: var(--shadow-blue); }

        .btn-secondary {
            background: transparent;
            color: var(--fg2);
            border: 1px solid var(--border);
        }

        .btn-secondary:hover { color: var(--fg); border-color: var(--fg2); background: var(--bg3); }

        .btn-disabled {
            background: var(--bg3);
            color: var(--fg3);
            border: 1px dashed var(--border);
            cursor: not-allowed;
            pointer-events: none;
            flex: 1;
        }

        .btn svg { width: 15px; height: 15px; }

        /* ── Empty state ── */
        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            color: var(--fg2);
        }

        /* ── Footer ── */
        footer {
            text-align: center;
            padding: 1.5rem;
            color: var(--fg3);
            font-size: 0.78rem;
            border-top: 1px solid var(--border);
            font-family: 'IBM Plex Mono', monospace;
        }

        footer a { color: var(--fg2); text-decoration: none; }
        footer a:hover { color: var(--accent); }

        @media (max-width: 640px) {
            .cards-grid { grid-template-columns: 1fr; }
            main { padding: 1.5rem 1rem 3rem; }
            .hero h1 { font-size: 1.8rem; }
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <a href="../index.html" class="navbar-brand-link">
            <div class="navbar-logo">@LOGO_CONTENT@</div>
            <span class="navbar-brand">@PROJECT_NAME@</span>
        </a>
        <span class="navbar-title">Coverage Dashboard</span>
        <a href="https://github.com/MohammadRaziei/ctoon" target="_blank" class="navbar-back">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>
            GitHub
        </a>
    </nav>

    <div class="hero">
        <div class="hero-label">Developer Tools</div>
        <h1>Coverage Reports</h1>
        <p>Detailed code coverage analysis for the @PROJECT_NAME@ project. Select a module to view the HTML report or download the raw data.</p>
    </div>

    <main>
        <div class="section-label">Modules</div>
        <div id="card-container" class="cards-grid">
            <!-- Cards injected by JavaScript -->
        </div>
    </main>

    <footer>
        <a href="https://github.com/MohammadRaziei/ctoon">CToon Project</a>
        &nbsp;·&nbsp; MIT License &nbsp;·&nbsp; Mohammad Raziei
    </footer>

    <script>
        const coverageData = @COVERAGE_DATA_JSON@;

        const icons = {
            code:  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
            total: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>`,
            link:  `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>`,
            download: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>`
        };

        // ── Parse LCOV to get overall line coverage % ────────────────────────
        function parseLcovCoverage(text) {
            let found = 0, hit = 0;
            for (const line of text.split('\n')) {
                if (line.startsWith('LF:'))  found += parseInt(line.slice(3)) || 0;
                if (line.startsWith('LH:'))  hit   += parseInt(line.slice(3)) || 0;
            }
            if (found === 0) return null;
            return (hit / found * 100).toFixed(1);
        }

        function covColor(pct) {
            if (pct === null) return null;
            return pct >= 80 ? '#40c057' : pct >= 50 ? '#fcc419' : '#ff6b6b';
        }

        function hexToRgba(hex, alpha) {
            const r = parseInt(hex.slice(1,3), 16);
            const g = parseInt(hex.slice(3,5), 16);
            const b = parseInt(hex.slice(5,7), 16);
            return `rgba(${r},${g},${b},${alpha})`;
        }

        // ── Render a card ────────────────────────────────────────────────────
        function renderCard(item, pct) {
            const color      = item.color;
            const badgeText  = pct !== null ? pct + '%' : item.badge;
            const barColor   = covColor(pct) || color;
            const isDisabled = item.htmlLink === '#';

            const barHtml = pct !== null ? `
                <div class="cov-bar-wrap">
                    <div class="cov-bar-top">
                        <span>Line coverage</span>
                        <span style="color:${barColor};font-weight:700">${pct}%</span>
                    </div>
                    <div class="cov-bar-track">
                        <div class="cov-bar-fill" style="width:${pct}%;background:${barColor}"></div>
                    </div>
                </div>` : '';

            return `
                <div class="card-header">
                    <div class="card-icon">${icons[item.id] || icons.code}</div>
                    <span class="badge" style="color:${pct !== null ? barColor : color};background:${hexToRgba(color,0.1)};border-color:${hexToRgba(color,0.3)}">${badgeText}</span>
                </div>
                <div class="card-title">${item.title}</div>
                <p class="card-desc">${item.desc}</p>
                ${barHtml}
                <div class="card-footer">
                    <a ${isDisabled ? '' : `href="${item.htmlLink}"`} class="${isDisabled ? 'btn btn-disabled' : 'btn btn-primary'}">
                        ${icons.link} View Report
                    </a>
                    <a href="${item.lcovLink}" class="btn btn-secondary" download>
                        ${icons.download} .lcov
                    </a>
                </div>`;
        }

        // ── Build all cards ──────────────────────────────────────────────────
        const container = document.getElementById('card-container');

        if (!coverageData || coverageData.length === 0) {
            container.innerHTML = `<div class="empty-state"><h3>No Coverage Data</h3><p>Could not load coverage reports.</p></div>`;
        } else {
            coverageData.forEach(item => {
                const card = document.createElement('div');
                card.className = 'card';
                card.style.setProperty('--card-color', item.color);
                card.innerHTML = renderCard(item, null);
                container.appendChild(card);

                // Fetch lcov and update card with real percentage
                fetch(item.lcovLink)
                    .then(r => r.ok ? r.text() : null)
                    .then(text => {
                        if (!text) return;
                        const pct = parseLcovCoverage(text);
                        const numPct = pct !== null ? parseFloat(pct) : null;
                        const barColor = covColor(numPct) || item.color;
                        // Update --card-color to match coverage level
                        card.style.setProperty('--card-color', barColor);
                        card.innerHTML = renderCard(item, numPct !== null ? pct : null);
                    })
                    .catch(() => {}); // silently ignore if lcov not available
            });
        }
    </script>
</body>
</html>