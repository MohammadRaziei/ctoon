<!DOCTYPE html>
<!--
    File: coverage_dashboard.html.in
    Description: This file serves as a modern, responsive dashboard for viewing code coverage reports.
                 It is designed to be generated by a build system (e.g., CMake) where project-specific
                 variables such as PROJECT_NAME and COVERAGE_DATA_JSON are injected.
                 The dashboard renders a list of coverage modules as interactive cards, allowing users
                 to view detailed HTML reports or download raw .lcov data files.
    
    Author: Mohammad Raziei
    Email: mohammadraziei1375@gmail.com
    GitHub: https://github.com/mohammadraziei
    
    MIT License:
    
    Permission is hereby granted, free of charge, to any person obtaining a copy
    of this software and associated documentation files (the "Software"), to deal
    in the Software without restriction, including without limitation the rights
    to use, copy, modify, merge, publish, distribute, sublicense, and/or sell
    copies of the Software, and to permit persons to whom the Software is
    furnished to do so, subject to the following conditions:
    
    The above copyright notice and this permission notice shall be included in all
    copies or substantial portions of the Software.
    
    THE SOFTWARE IS PROVIDED "AS IS", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR
    IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,
    FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE
    AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER
    LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM,
    OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE
    SOFTWARE.
-->
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@PROJECT_NAME@ Coverage Report</title>
    <style>
        :root {
            /* Furo Dark Theme Palette */
            --bg-body: #121212;
            --bg-sidebar: #1e1e1e;
            --bg-card: #1e1e1e;
            --bg-hover: #2d2d2d;
            
            --text-main: #e0e0e0;
            --text-muted: #a0a0a0;
            --border-color: #333333;
            
            --accent-primary: #4dabf7; /* Default fallback, will be overridden by JS */
            
            --shadow-card: 0 4px 6px -1px rgba(0, 0, 0, 0.5);
            --shadow-hover: 0 10px 15px -3px rgba(0, 0, 0, 0.6);
            
            --radius: 8px;
            --font-main: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; outline: none; }

        body {
            background-color: var(--bg-body);
            color: var(--text-main);
            font-family: var(--font-main);
            line-height: 1.6;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* --- Navbar --- */
        .navbar {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem 1.5rem;
            background-color: var(--bg-sidebar);
            border-bottom: 1px solid var(--border-color);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .navbar-logo {
            width: 28px;
            height: 28px;
            flex-shrink: 0;
        }

        .navbar-logo > * {
            width: 100%;
            height: auto;
        }

        .navbar-logo svg path,
        .navbar-logo svg polygon,
        .navbar-logo svg rect,
        .navbar-logo svg circle,
        .navbar-logo svg g {
            fill: var(--accent-primary) !important;
            stroke: var(--accent-primary) !important;
        }

        .navbar-brand {
            font-size: 1rem;
            font-weight: 700;
            color: var(--text-main);
            letter-spacing: -0.01em;
        }

        .navbar-title {
            color: var(--text-muted);
            font-size: 0.85rem;
            margin-left: 0.5rem;
            padding-left: 0.75rem;
            border-left: 1px solid var(--border-color);
        }

        /* --- Main Layout --- */
        main {
            flex: 1;
            padding: 3rem 2rem;
            max-width: 1250px; 
            margin: 0 auto;
            width: 100%;
        }

        /* Intro Section */
        .intro-section {
            margin-bottom: 3rem;
            text-align: center;
        }
        .intro-title {
            font-size: 1.8rem;
            font-weight: 700;
            margin-bottom: 1rem;
            color: var(--text-main);
        }
        .intro-desc {
            color: var(--text-muted);
            font-size: 1.1rem;
            margin: 0 auto;
            text-align: justify;
        }

        /* Stack Container: Cards strictly below each other */
        .stack-container {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        /* --- Cards --- */
        .card {
            background-color: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: var(--radius);
            padding: 2rem;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
            box-shadow: var(--shadow-card);
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        /* Top accent bar */
        .card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: var(--accent-primary);
            opacity: 0.6;
            transition: opacity 0.3s ease;
        }

        .card:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-hover);
            border-color: var(--accent-primary);
        }

        .card:hover::before {
            opacity: 1;
        }

        /* Header Row: Icon + Title + Badge */
        .card-header {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .icon-wrapper {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            background-color: rgba(255, 255, 255, 0.05);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--accent-primary);
            transition: background-color 0.3s ease;
            flex-shrink: 0;
        }

        .card:hover .icon-wrapper {
            filter: brightness(1.2);
        }

        .icon-wrapper svg {
            width: 26px;
            height: 26px;
            stroke-width: 1.5;
        }

        .title-badge-group {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
            flex: 1;
        }

        .card-title {
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--text-main);
        }

        .badge {
            font-size: 0.75rem;
            font-weight: 700;
            padding: 0.2rem 0.6rem;
            border-radius: 20px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            background-color: rgba(255, 255, 255, 0.1);
            color: var(--text-muted);
            border: 1px solid transparent;
            align-self: flex-start;
            /* Push badge to the right */
            margin-left: auto;
        }

        .card-desc {
            color: var(--text-muted);
            font-size: 0.95rem;
            margin-bottom: 0.5rem;
        }

        /* --- Actions --- */
        .card-actions {
            display: flex;
            gap: 1rem;
            margin-top: auto;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            padding-top: 1.5rem;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 0.6rem 1.25rem;
            border-radius: 6px;
            font-size: 0.9rem;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s ease;
            cursor: pointer;
            width: auto; 
        }

        .btn-primary {
            background-color: var(--accent-primary);
            color: #fff;
            border: 1px solid transparent;
        }

        .btn-primary:hover {
            /* Use brightness to lighten the color */
            filter: brightness(1.2);
            box-shadow: 0 0 15px rgba(0,0,0,0.2);
        }

        .btn-secondary {
            background-color: transparent;
            color: var(--text-main);
            border: 1px solid var(--border-color);
        }

        .btn-secondary:hover {
            background-color: var(--bg-hover);
            border-color: var(--text-muted);
        }

        .btn-disabled {
            background-color: rgba(255, 255, 255, 0.03);
            color: var(--text-muted);
            border: 1px dashed var(--border-color);
            cursor: not-allowed;
            pointer-events: none;
        }

        /* --- Footer --- */
        footer {
            text-align: center;
            padding: 2rem;
            color: var(--text-muted);
            font-size: 0.85rem;
            border-top: 1px solid var(--border-color);
            margin-top: 4rem;
        }

        /* --- Empty State --- */
        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            color: var(--text-muted);
        }
    </style>
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar">
        <div class="navbar-logo">
            @LOGO_CONTENT@
        </div>
        <span class="navbar-brand">@PROJECT_NAME@</span>
        <span class="navbar-title">Coverage Dashboard</span>
    </nav>

    <main>
        <div class="intro-section">
            <h1 class="intro-title">@PROJECT_NAME@ Coverage Reports</h1>
            <p class="intro-desc">
                Access detailed code coverage analysis and reports for the @PROJECT_NAME@ project.
                Select a module below to view the HTML report or download the raw data.
            </p>
        </div>

        <div id="card-container" class="stack-container">
            <!-- Cards will be injected here by JavaScript -->
        </div>
    </main>

    <footer>
        <p>Created By Mohammad Raziei &bull; @PROJECT_NAME@ Project</p>
    </footer>

    <script>
        // Data injected from CMake
        const coverageData = @COVERAGE_DATA_JSON@;

        // SVG Icons
        const icons = {
            code: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>`,
            total: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>`,
            link: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>`,
            download: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>`
        };

        const container = document.getElementById('card-container');

        if (coverageData && coverageData.length > 0) {
            coverageData.forEach(item => {
                const card = document.createElement('div');
                card.className = 'card';
                
                const iconSvg = icons[item.id] || icons.code;
                
                // Determine button state
                const isDisabled = item.htmlLink === "#";
                const btnClass = isDisabled ? "btn btn-disabled" : "btn btn-primary";
                const btnAttr = isDisabled ? "" : `href="${item.htmlLink}"`;
                
                // Dynamic styling based on item color
                const iconStyle = `color: ${item.color};`;
                const badgeStyle = `background-color: ${hexToRgba(item.color, 0.15)}; color: ${item.color}; border: 1px solid ${hexToRgba(item.color, 0.3)};`;

                card.innerHTML = `
                    <div class="card-header">
                        <div class="icon-wrapper" style="${iconStyle}">
                            ${iconSvg}
                        </div>
                        <div class="title-badge-group">
                            <div class="card-title">${item.title}</div>
                        </div>
                        <span class="badge" style="${badgeStyle}">${item.badge}</span>
                    </div>
                    <p class="card-desc">${item.desc}</p>
                    <div class="card-actions">
                        <a ${btnAttr} class="${btnClass}">
                            ${icons.link}
                            View Report
                        </a>
                        <a href="${item.lcovLink}" class="btn btn-secondary" download>
                            ${icons.download}
                            Download .lcov
                        </a>
                    </div>
                `;
                
                // Set the accent color dynamically for hover effects
                card.style.setProperty('--accent-primary', item.color);

                container.appendChild(card);
            });
        } else {
            container.innerHTML = `
                <div class="empty-state">
                    <h3>No Coverage Data Available</h3>
                    <p>Could not load coverage reports.</p>
                </div>
            `;
        }

        function hexToRgba(hex, alpha) {
            const r = parseInt(hex.slice(1, 3), 16);
            const g = parseInt(hex.slice(3, 5), 16);
            const b = parseInt(hex.slice(5, 7), 16);
            return `rgba(${r}, ${g}, ${b}, ${alpha})`;
        }
    </script>
</body>
</html>