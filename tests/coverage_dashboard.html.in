<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CToon Coverage Dashboard</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 2rem;
            color: #333;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .header {
            text-align: center;
            color: white;
            margin-bottom: 2rem;
        }

        .header h1 {
            font-size: 2.5rem;
            margin-bottom: 0.5rem;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }

        .header p {
            font-size: 1.1rem;
            opacity: 0.9;
        }

        .dashboard {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .card {
            background: white;
            border-radius: 12px;
            padding: 1.5rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(0,0,0,0.3);
        }

        .card-header {
            display: flex;
            align-items: center;
            margin-bottom: 1rem;
            padding-bottom: 1rem;
            border-bottom: 2px solid #f0f0f0;
        }

        .card-icon {
            width: 50px;
            height: 50px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 1rem;
            font-size: 1.5rem;
            color: white;
        }

        .card-title {
            flex: 1;
        }

        .card-title h3 {
            font-size: 1.3rem;
            margin-bottom: 0.3rem;
        }

        .badge {
            display: inline-block;
            padding: 0.3rem 0.8rem;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
            color: white;
        }

        .badge.native { background: #f0883e; }
        .badge.interpreter { background: #3572A5; }
        .badge.total { background: #a371f7; }

        .card-description {
            color: #666;
            line-height: 1.6;
            margin-bottom: 1rem;
        }

        .card-actions {
            display: flex;
            gap: 0.5rem;
        }

        .btn {
            display: inline-block;
            padding: 0.6rem 1.2rem;
            border-radius: 6px;
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 500;
            transition: all 0.2s ease;
            flex: 1;
            text-align: center;
        }

        .btn-primary {
            background: #0366d6;
            color: white;
        }

        .btn-primary:hover {
            background: #0256b9;
        }

        .btn-secondary {
            background: #f6f8fa;
            color: #0366d6;
            border: 1px solid #e1e4e8;
        }

        .btn-secondary:hover {
            background: #e1e4e8;
        }

        .footer {
            text-align: center;
            color: white;
            padding: 1rem;
            opacity: 0.8;
        }

        @media (max-width: 768px) {
            .dashboard {
                grid-template-columns: 1fr;
            }
            
            .header h1 {
                font-size: 2rem;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>📊 CToon Coverage Dashboard</h1>
            <p>Code Coverage Reports for C++ and Python</p>
        </div>

        <div class="dashboard">
            @COVERAGE_DATA_JSON@
        </div>

        <div class="footer">
            <p>Generated by CToon CMake Build System</p>
        </div>
    </div>

    <script>
        // Coverage data
        const coverageData = @COVERAGE_DATA_JSON@;

        // Render coverage cards
        const dashboard = document.querySelector('.dashboard');
        dashboard.innerHTML = '';

        coverageData.forEach(report => {
            const card = document.createElement('div');
            card.className = 'card';
            
            const iconBg = report.color;
            const icon = report.badgeClass === 'native' ? '🔧' : 
                        report.badgeClass === 'interpreter' ? '🐍' : '📈';

            card.innerHTML = `
                <div class="card-header">
                    <div class="card-icon" style="background: ${iconBg}">
                        ${icon}
                    </div>
                    <div class="card-title">
                        <h3>${report.title}</h3>
                        <span class="badge ${report.badgeClass}">${report.badge}</span>
                    </div>
                </div>
                <p class="card-description">${report.desc}</p>
                <div class="card-actions">
                    <a href="${report.htmlLink}" class="btn btn-primary">View HTML Report</a>
                    <a href="${report.lcovLink}" class="btn btn-secondary">Download LCOV</a>
                </div>
            `;
            
            dashboard.appendChild(card);
        });
    </script>
</body>
</html>
